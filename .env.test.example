# Playwright E2E Test Environment Variables
# Copy this file to .env.test and fill in test-specific values

# Test Server Configuration
PLAYWRIGHT_TEST_BASE_URL=http://localhost:3000

# Stripe Test Keys (Use Test Mode keys only)
# These should be your Stripe Test Mode (Publishable Key)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key_here

# Stripe Test Mode Secret Key (for test database seeding if needed)
STRIPE_SECRET_KEY=sk_test_your_test_key_here

# Test Database Configuration
# Use a separate test MongoDB instance or test collection prefix
MONGODB_URI=mongodb+srv://test:password@cluster.mongodb.net/snatchi_test?retryWrites=true&w=majority

# NextAuth Configuration
NEXTAUTH_SECRET=your_test_secret_key_for_nextauth
NEXTAUTH_URL=http://localhost:3000

# Test Stripe Price IDs (from Stripe Test Mode)
# These should be actual test price IDs from your Stripe test mode
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=price_test_starter_abc123
NEXT_PUBLIC_STRIPE_PROFESSIONAL_PRICE_ID=price_test_professional_def456
NEXT_PUBLIC_STRIPE_ENTERPRISE_PRICE_ID=price_test_enterprise_ghi789

# Brevo Email Configuration (optional, can be mocked)
BREVO_API_KEY=test_key_or_leave_empty_to_mock

# Other Test Configuration
NODE_ENV=test

# Webhook Test Configuration
WEBHOOK_SECRET=whsec_test_your_webhook_secret

# Optional: Enable verbose logging during tests
# DEBUG=true
